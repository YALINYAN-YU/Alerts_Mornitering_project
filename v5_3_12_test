def get_table3(df):
    
    df3_1 = df.pivot(index='alert_timestamp', columns='alert_name', values='alert_count')
    df3_2 = df3_1.fillna(0)
    df3_2['alert_timestamp']= df3_2.index
    
    cols = list(df3_2.columns)
    cols = [cols[-1]] + cols[:-1]
    df3_3 = df3_2[cols]   
    
    df3_4 = df3_3.sort_values(by=['alert_timestamp'], ascending=False)
    df3_5 = df3_4.reset_index(drop=True)
    df3_5.columns = df3_5.columns.str.replace('?', ' ')
    
    df3_6 = df3_5.set_index(['alert_timestamp']).sort_index(ascending=True).asfreq(freq ='H', fill_value = 0)
    df3_7 = df3_6.rolling('12H').sum()
    df3_8 = df3_7.sort_index(ascending=False)
    df3_9 = df3_8.iloc[::12, :]
    df3_9.reset_index(inplace=True)
    df3_10 = df3_9.rename(columns = {'index':'alert_timestamp'})
    table3 = df3_10
    
    return table3
