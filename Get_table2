def get_table2(sql):
    """
    Simple function to execute a query by using run_query function, query to union 8 source tables to table2 
    Including process of judging the right value and pass to 'alert_count'
    Option to return results as a dataframe
    """
    df1 = run_query(sql_table2, framed = True)
    df1['alert_count'] = pd.np.where(df1.alert_name.str.contains("Account Count"), df1['acct_count'], df1['session_count'])
    df2 = df1[['alert_timestamp', 'alert_name', 'alert_count']]
    
    return df2
